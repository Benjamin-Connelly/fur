.SH NAME
fur-config - Inspect and manage fur configuration


.SH SYNOPSIS
\fBfur config [flags]\fP


.SH DESCRIPTION
Inspect and manage the fur configuration file at ~/.config/fur/config.yaml.

.PP
Subcommands:
  init   Write a starter config.yaml with all keys documented.
  path   Print the resolved config file path.
  show   Print the active config (file + flags merged).


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for config


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file path

.PP
\fB--debug\fP[=false]
	enable verbose logging

.PP
\fB--no-color\fP[=false]
	disable colors (ascii theme)

.PP
\fB--show-hidden\fP[=false]
	show dotfiles and dotdirs (.git/.hg/.svn/.bzr always hidden)

.PP
\fB--theme\fP=""
	color theme (light|dark|auto|ascii)


