.SH NAME
fur-config-init - Write a starter config.yaml at ~/.config/fur/config.yaml


.SH SYNOPSIS
\fBfur config init [flags]\fP


.SH DESCRIPTION
Write a default config.yaml at ~/.config/fur/config.yaml.

.PP
Without --force the command refuses to overwrite an existing file.
With --force the existing file is renamed to config.yaml.bak before
the new file is written.


.SH OPTIONS
\fB--force\fP[=false]
	overwrite existing config (creates config.yaml.bak)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for init


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file path

.PP
\fB--debug\fP[=false]
	enable verbose logging

.PP
\fB--no-color\fP[=false]
	disable colors (ascii theme)

.PP
\fB--show-hidden\fP[=false]
	show dotfiles and dotdirs (.git/.hg/.svn/.bzr always hidden)

.PP
\fB--theme\fP=""
	color theme (light|dark|auto|ascii)


.SH EXAMPLE
.EX
  fur config init
  fur config init --force
.EE


.SH SEE ALSO
\fBfur-config(1)\fP


